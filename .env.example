# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database (PostgreSQL) — consumed by Prisma
# When running via docker-compose the host is the compose service name `postgres`.
# For LOCAL tooling the container publishes Postgres on host port 5433 (5432 is
# often taken by a native Postgres install).
# ---------------------------------------------------------------------------
POSTGRES_USER=iam
POSTGRES_PASSWORD=iam_secret
POSTGRES_DB=iam
DATABASE_URL=postgresql://iam:iam_secret@localhost:5433/iam?schema=public

# ---------------------------------------------------------------------------
# Security / JWT  (NEVER commit real secrets — override in each environment)
# ---------------------------------------------------------------------------
# NOTE: reference impl uses HS256 (symmetric). Production target is RS256/EdDSA
# + JWKS so services verify tokens without sharing the secret (see DESIGN.md §9).
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# GraphQL
# ---------------------------------------------------------------------------
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true
